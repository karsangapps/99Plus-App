[
  {
    "id": "TC001",
    "title": "Create a student account successfully and reach Eligibility onboarding",
    "description": "Verifies that a new student can sign up with valid details and is routed to the eligibility onboarding page.",
    "category": "Student Signup & Onboarding",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /signup"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Create Account\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"Test Student\" into the full name field"
      },
      {
        "type": "action",
        "description": "Type \"test.student+e2e@invalid-example.com\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"9999999999\" into the phone field"
      },
      {
        "type": "action",
        "description": "Type \"2004-05-15\" into the date of birth field"
      },
      {
        "type": "action",
        "description": "Type \"ValidPassword123!\" into the password field"
      },
      {
        "type": "action",
        "description": "Click on a target university option to select it"
      },
      {
        "type": "action",
        "description": "Click on the terms/privacy acceptance checkbox"
      },
      {
        "type": "action",
        "description": "Click on \"Create Account\""
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/onboarding/eligibility\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Subject\" is visible"
      }
    ]
  },
